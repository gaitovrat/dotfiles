filetype plugin indent on
set noswapfile
set nocompatible
set hidden
set nohlsearch
syntax enable
set splitbelow
set splitright
set mouse=a
set mousehide
set encoding=utf-8
set smartindent
set copyindent
set smarttab
set tabstop=4
set shiftwidth=4
set expandtab
set softtabstop=4
set number relativenumber
set wrap linebreak nolist
set showtabline=1
set ignorecase
set smartcase
set foldnestmax=10
set foldlevel=2
set nofoldenable
set foldlevelstart=0
set t_Co=256
set vb
set t_ut=""
set backspace=indent,eol,start

let mapleader = " "

map <leader>; :

map <leader>wh <c-w>h
map <leader>wl <c-w>l
map <leader>wj <c-w>j
map <leader>wk <c-w>k

map <leader>v :vsplit<cr>
map <leader>s :split<cr>

nmap <leader>fs :w<cr>
nmap <leader>wq :q<cr>
nmap <leader>wx :x<cr>

